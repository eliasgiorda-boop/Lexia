# Copiar este archivo a .env y completar los valores reales
# El archivo .env NUNCA debe subirse al repo (está en .gitignore)

OPENAI_API_KEY=sk-proj-tu-key-va-aca

# Path al corpus de normativa (las copias originales del scraper)
CORPUS_PATH=E:\Bosio\Normativa Total\Por Tipo Normativa

# Path a la Carta Orgánica
CARTA_ORGANICA_PATH=E:\Bosio\Normativa Total\carta-organica-municipal.pdf

# Modelo de embeddings a usar
EMBEDDING_MODEL=text-embedding-3-small

# Path donde vive la base vectorial
CHROMADB_PATH=./data/chromadb
# Modelo LLM para generar respuestas (Capa 2)
LLM_MODEL=gpt-4.1
